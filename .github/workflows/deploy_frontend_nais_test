name: Deploy frontend to TEST
on:
  workflow_dispatch:

jobs:
  build_and_deploy:
    name: Build, push and deploy
    runs-on: ubuntu-latest
    environment: 'test'
    permissions:
      contents: read
      id-token: write
    steps:
      - uses: actions/checkout@v4
      - name: Build and push image and SBOM to OCI registry
        uses: nais/docker-build-push@v0
        id: docker-build-push
        with:
          team: ssbno
          tag: latest
          identity_provider: ${{ secrets.NAIS_WORKLOAD_IDENTITY_PROVIDER }} # Provided as Organization Secret
          project_id: ${{ secrets.NAIS_MANAGEMENT_PROJECT_ID }}  # Provided as Organization Variable
          dockerfile: PxGraf.Frontend/Dockerfile # optional, default docker_context/Dockerfile
          image_suffix: frontend # optional, default empty
      - name: Deploy to NAIS
        uses: nais/deploy/actions/deploy@v2
        env:
          TEAM: ssbno
          CLUSTER: test
          RESOURCE: .nais/frontend-test.yaml
          VAR: image=${{ steps.docker-build-push.outputs.image }}
          TELEMETRY: ${{ steps.docker-build-push.outputs.telemetry }}
          DEPLOY_SERVER: deploy.ssb.cloud.nais.io:443
