{
  "LogOptions": {
    "Folder": "<path to logs>", // Fill path to the log directory
    "SysId": "PxGraf",
    "Level": "Information",
    "AuditLog": {
      "Enabled": false,
      "IncludedHeaders": []
    }
  },
  "ApplicationInsights": {
    "ConnectionString": "", // Fill Application Insights connection string
    "EnableAdaptiveSampling": false,
    "MinLevel": "Information"
  },
  "CacheOptions": { // Sliding expiration is counted from the latest cache read
    "Meta": {
      "SlidingExpirationMinutes": "2",
      "AbsoluteExpirationMinutes": "15"
    },
    "Data": {
      "SlidingExpirationMinutes": "30",
      "AbsoluteExpirationMinutes": "120"
    },
    "Database": {
      "AbsoluteExpirationMinutes": "5",
      "SlidingExpirationMinutes": "2",
      "ItemAmountLimit": "1000" // responses
    },
    "Table": {
      "SlidingExpirationMinutes": "5"
    },
    "Visualization": {
      "SlidingExpirationMinutes": "15",
      "AbsoluteExpirationMinutes": "720", // 12 hours
      "ItemAmountLimit": "1000" // responses
    },
    "CacheFreshnessCheckIntervalSeconds": "45"
  },
  "Cors": {
    "AllowAnyOrigin": false,
    "AllowedOrigins": [ "example.com" ]
  },
  "QueryOptions": {
    "MaxHeaderLength": 180,
    "MaxQuerySize": 100000
  },
  "Language": {
    "Default": "en",
    "Available": [ "en" ]
  },
  // DATA SOURCE CONFIGURATION - Set DatabaseConfig.Type to one of: PxWeb, LocalFileSystem, BlobContainer.
  // Include only the fields relevant to your chosen type. Missing required fields will cause a startup error.
  "DatabaseConfig": {
    "Type": "LocalFileSystem", // PxWeb | LocalFileSystem | BlobContainer
    "PxWebUrl": "http://localhost:56338/", // Required for Type: PxWeb
    "DatabaseRootPath": "", // Required for Type: LocalFileSystem
    "Encoding": "", // Required for Type: LocalFileSystem (e.g., "utf-8", "latin1")
    "StorageAccountName": "", // Required for Type: BlobContainer
    "ContainerName": "", // Required for Type: BlobContainer
    "RootPath": "", // Optional for Type: BlobContainer (e.g., "px-data/")
    "ManagedIdentityClientId": "" // Optional for Type: BlobContainer (Client ID of User-Assigned Managed Identity)
  },
  "FeatureManagement": {
    "CreationAPI": true // Enables/disables the creation controller.
  },
  // QUERY STORAGE CONFIGURATION - Set QueryStorageConfig.Type to one of: LocalFileSystem, BlobContainer.
  // Legacy savedQueryDirectory/archiveFileDirectory are also supported as fallback when this section is absent.
  "savedQueryDirectory": "<path to query files>", // LEGACY fallback: Use QueryStorageConfig instead.
  "archiveFileDirectory": "<path to archive files>", // LEGACY fallback: Use QueryStorageConfig instead.
  "QueryStorageConfig": {
    "Type": "LocalFileSystem", // LocalFileSystem | BlobContainer
    "SavedQueryDirectory": "", // Required for Type: LocalFileSystem
    "ArchiveFileDirectory": "", // Required for Type: LocalFileSystem
    "StorageAccountName": "", // Required for Type: BlobContainer
    "ContainerName": "", // Required for Type: BlobContainer
    "SavedQueryPath": "saved-queries", // Optional for Type: BlobContainer
    "ArchiveFilePath": "archive-files", // Optional for Type: BlobContainer
    "ManagedIdentityClientId": "" // Optional for Type: BlobContainer (Client ID of User-Assigned Managed Identity)
  },
  "PublicationWebhookConfiguration": { // Optional configuration for publication webhooks triggered when queries are saved/archived in non-draft mode.
    "EndpointUrl": "", // URL where webhook POST requests will be sent
    "AccessTokenHeaderName": "", // Optional HTTP header name for access token authentication
    "AccessTokenHeaderValue": "", // Optional access token value
    "BodyContentPropertyNames": [], // List of properties to include: Id, ChartHeaderEdit, Archived, ContainsSelectableDimensions, VisualizationType, TableReference, Note, CreationTime, Draft, Version
    "BodyContentPropertyNameEdits": {}, // Optional mapping of standard property names to custom field names: {"Archived": "Static", "ContainsSelectableDimensions": "Selectable"}
    "VisualizationTypeTranslations": {}, // Optional mapping of VisualizationType enum values to custom strings: {"LineChart": "LC", "VerticalBarChart": "VBC"}
    "MetadataProperties": {} // Optional mapping of px file metadata property keys to webhook body field names: {"DESCRIPTION": "Info", "TITLE": "Header"}
  }
}